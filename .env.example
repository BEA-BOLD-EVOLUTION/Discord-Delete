# Copy to `.env` and fill in. Never commit your real `.env`.

# Discord bot token from the Developer Portal (Bot -> Reset Token)
DISCORD_TOKEN=

# PostgreSQL connection string
DATABASE_URL=postgresql://discord:discord@localhost:5432/discorddelete

# How often (in minutes) the automatic sweep runs. Default 60.
SWEEP_INTERVAL_MINUTES=60

# How long (in days) archived messages are retained before being purged.
# A daily job deletes archive rows older than this. Default 90.
ARCHIVE_RETENTION_DAYS=90

# Optional: a single guild ID to sync slash commands to instantly during
# development. Leave blank to sync commands globally (can take up to ~1 hour
# to propagate the first time).
DEV_GUILD_ID=
